{
  "manifest_version": 3,
  "name": "トランスポート福岡 リード監視",
  "version": "0.38.1",
  "description": "一括査定サイトの顧客一覧を監視し、新規リードと詳細を自動でサーバーへ送信します（ズバット・引越し侍・価格.com）。3サイトとも自動再ログイン対応。通知メッセージ送信・削除対応。",
  "permissions": ["storage", "scripting", "alarms", "notifications"],
  "host_permissions": [
    "https://hikkoshi-kanri.zba.jp/*",
    "https://hikkosizamurai.com/*",
    "https://ssl.kakaku.com/*",
    "https://transportfukuoka.vercel.app/*"
  ],
  "icons": { "128": "icon128.png" },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "リード監視",
    "default_icon": { "128": "icon128.png" }
  },
  "content_scripts": [
    {
      "matches": ["https://hikkoshi-kanri.zba.jp/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
