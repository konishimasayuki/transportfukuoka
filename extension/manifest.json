{
  "manifest_version": 3,
  "name": "トランスポート福岡 リード監視",
  "version": "0.1.0",
  "description": "一括査定サイトの顧客一覧を監視し、新規リードをサーバーへ送信します（まずは引越し侍）。",
  "permissions": ["storage"],
  "host_permissions": [
    "https://*.hikkoshizamurai.jp/*",
    "https://transportfukuoka.vercel.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "リード監視"
  },
  "content_scripts": [
    {
      "matches": ["https://*.hikkoshizamurai.jp/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
